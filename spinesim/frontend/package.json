{
  "name": "vertex-frontend",
  "version": "0.2.0",
  "private": true,
  "description": "VERTEX© — Interface 3D de simulation biomécanique du rachis",
  "type": "module",
  "scripts": {
    "dev":            "vite",
    "build":          "vite build",
