    "@vueuse/core": "^10.7.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue":      "^5.0.0",
    "vite":                    "^5.1.0",
    "vitest":                  "^1.6.0",
    "@vitest/coverage-istanbul": "^1.6.0",
    "@vue/test-utils":         "^2.4.5",
    "jsdom":                   "^24.0.0",
    "@playwright/test":        "^1.44.0"
